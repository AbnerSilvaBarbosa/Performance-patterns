{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/with-cache/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/with-cache/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/*",
  "projects": {
    "database": {
      "type": "library",
      "root": "libs/database",
      "entryFile": "index",
      "sourceRoot": "libs/database/src",
      "compilerOptions": {
        "tsConfigPath": "libs/database/tsconfig.lib.json"
      }
    },
    "metrics": {
      "type": "library",
      "root": "libs/metrics",
      "entryFile": "index",
      "sourceRoot": "libs/metrics/src",
      "compilerOptions": {
        "tsConfigPath": "libs/metrics/tsconfig.lib.json"
      }
    },
    "cache": {
      "type": "library",
      "root": "libs/cache",
      "entryFile": "index",
      "sourceRoot": "libs/cache/src",
      "compilerOptions": {
        "tsConfigPath": "libs/cache/tsconfig.lib.json"
      }
    },
    "with-cache": {
      "type": "application",
      "root": "apps/with-cache",
      "entryFile": "main",
      "sourceRoot": "apps/with-cache/src",
      "compilerOptions": {
        "tsConfigPath": "apps/with-cache/tsconfig.app.json"
      }
    },
    "without-cache": {
      "type": "application",
      "root": "apps/without-cache",
      "entryFile": "main",
      "sourceRoot": "apps/without-cache/src",
      "compilerOptions": {
        "tsConfigPath": "apps/without-cache/tsconfig.app.json"
      }
    }
  }
}